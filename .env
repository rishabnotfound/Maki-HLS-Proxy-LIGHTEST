# Your public proxy URL (used for rewriting URLs in playlists)
# Change this to your domain when deploying
PROXY_HOST=http://localhost

# Cache settings
# Set to 0 to disable caching, 1g is 1gb btw
CACHE_SIZE=5g

# Cache expiry (how long unused cache stays before deletion)
# Examples: 1d, 12h, 7d
CACHE_EXPIRY=1d
